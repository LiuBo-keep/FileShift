<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<BorderPane fx:id="rootPane" fx:controller="org.fileshift.controller.MainController"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">

    <!-- 函数组 -->
    <fx:define>
        <ToggleGroup fx:id="functionGroup"/>
    </fx:define>

    <!-- 左侧菜单 -->
    <left>
        <VBox styleClass="sidebar" fx:id="sidebar" prefWidth="230">
            <padding>
                <Insets top="12" right="12" bottom="12" left="12"/>
            </padding>
            <Label text="转换功能" styleClass="sidebar-title"/>

            <RadioButton text="图片 → PDF"
                         fx:id="rbImageToPdf"
                         toggleGroup="$functionGroup"
                         selected="true"
                         styleClass="nav-radio"/>

            <RadioButton text="Word/Excel → PDF"
                         fx:id="rbOfficeToPdf"
                         toggleGroup="$functionGroup"
                         styleClass="nav-radio"/>

            <RadioButton text="PDF -> Word"
                         fx:id="rbPdfToWord"
                         toggleGroup="$functionGroup"
                         styleClass="nav-radio"/>

            <VBox VBox.vgrow="ALWAYS"/>

            <HBox alignment="CENTER_LEFT" spacing="8">
                <padding>
                    <Insets top="8" right="0" bottom="0" left="0"/>
                </padding>
                <Label text="深色模式" styleClass="theme-label"/>
                <CheckBox fx:id="chkDarkMode" selected="false"/>
            </HBox>
        </VBox>
    </left>

    <!-- 中间内容 -->
    <center>
        <BorderPane>
            <center>
                <StackPane>
                    <!-- 图片面板 -->
                    <VBox fx:id="paneImageToPdf" visible="true">
                        <padding>
                            <Insets top="16" right="16" bottom="0" left="16"/>
                        </padding>
                        <Label text="拖拽图片文件（支持 PNG/JPG/JPEG/BMP/GIF）到下方列表"
                               styleClass="drop-hint"/>
                        <TableView fx:id="tableFiles" VBox.vgrow="ALWAYS">
                            <placeholder>
                                <Label text="拖拽文件到此处（或点击空白区域）"
                                       styleClass="placeholder-label"/>
                            </placeholder>
                            <columns>
                                <TableColumn text="文件名" fx:id="colName" prefWidth="300"/>
                                <TableColumn text="状态" fx:id="colStatus" prefWidth="140"/>
                                <TableColumn text="进度" fx:id="colProgress" prefWidth="160"/>
                            </columns>
                        </TableView>
                    </VBox>

                    <!-- Office 面板 -->
                    <VBox fx:id="paneOfficeToPdf" visible="false">
                        <padding>
                            <Insets top="16" right="16" bottom="0" left="16"/>
                        </padding>
                        <Label text="拖拽 Word 或 Excel 文件（支持 .doc/.docx/.xls/.xlsx）到下方列表"
                               styleClass="drop-hint"/>
                        <TableView fx:id="tableOffice" VBox.vgrow="ALWAYS">
                            <placeholder>
                                <Label text="拖拽 Word/Excel 文件到此处"
                                       styleClass="placeholder-label"/>
                            </placeholder>
                            <columns>
                                <TableColumn text="文件名" fx:id="colNameOffice" prefWidth="300"/>
                                <TableColumn text="状态" fx:id="colStatusOffice" prefWidth="140"/>
                                <TableColumn text="进度" fx:id="colProgressOffice" prefWidth="160"/>
                            </columns>
                        </TableView>
                    </VBox>

                    <!-- PDF转Word 面板 -->
                    <VBox fx:id="panePdfToWord" visible="false">
                        <padding>
                            <Insets top="16" right="16" bottom="0" left="16"/>
                        </padding>
                        <Label text="拖拽 PDF 文件（支持 .pdf）到下方列表"
                               styleClass="drop-hint"/>
                        <TableView fx:id="tablePdfToWord" VBox.vgrow="ALWAYS">
                            <placeholder>
                                <Label text="拖拽 PDF 文件到此处"
                                       styleClass="placeholder-label"/>
                            </placeholder>
                            <columns>
                                <TableColumn text="文件名" fx:id="colStatusPdfToWord" prefWidth="300"/>
                                <TableColumn text="状态" fx:id="colNamePdfToWord" prefWidth="140"/>
                                <TableColumn text="进度" fx:id="colProgressPdfToWord" prefWidth="160"/>
                            </columns>
                        </TableView>
                    </VBox>

                    <!-- 通知容器 -->
                    <VBox fx:id="notificationContainer"
                          alignment="TOP_CENTER"
                          visible="false"
                          style="-fx-translate-y: -100; -fx-opacity: 0; -fx-padding: 20;">
                        <Label fx:id="notificationLabel" styleClass="notification-label"/>
                    </VBox>
                </StackPane>
            </center>

            <!-- 底部栏 -->
            <bottom>
                <StackPane alignment="BOTTOM_RIGHT">
                    <HBox alignment="CENTER_LEFT"
                          spacing="20"
                          styleClass="bottom-bar"
                          style="-fx-padding: 12 20 12 20;">

                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <Button fx:id="btnChooseOutput" text="选择输出文件夹" prefWidth="140"
                                    styleClass="action-btn"/>
                            <Label fx:id="lblOutputDir"
                                   text="输出：原文件所在目录"
                                   styleClass="output-label"/>
                        </HBox>

                        <Region HBox.hgrow="ALWAYS"/>

                        <HBox alignment="CENTER_RIGHT" spacing="16">
                            <ProgressBar fx:id="globalProgress" prefWidth="300" progress="0"
                                         styleClass="global-progress"/>
                            <Button text="开始转换" fx:id="btnStart" defaultButton="true" prefWidth="120"
                                    styleClass="primary-btn"/>

                            <Button fx:id="btnDelete" text="删除选中" prefWidth="120"
                                    styleClass="action-btn" disable="true"/>
                        </HBox>
                    </HBox>
                </StackPane>
            </bottom>
        </BorderPane>
    </center>

    <stylesheets>
        <URL value="@../css/styles.css"/>
    </stylesheets>
</BorderPane>